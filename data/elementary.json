    "category": "實驗設計",
    "distractor_pool": "experiment_design"
  },
  {
    "id": "e0011",
    "term": "公平測試",
    "unit": "inquiry",
    "grade": "5",
    "def": "一次只改變一個主要因素，其餘條件盡量相同的實驗方式。",
