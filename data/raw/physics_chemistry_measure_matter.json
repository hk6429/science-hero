[
  {
    "id": "pc0001",
    "term": "物理量",
    "unit": "measure_matter",
    "grade": "8",
    "def": "可用數值和單位表示，並能透過測量得到的性質。",
    "example": "物理量：小安量得課桌長 120 公分，其中長度就是一個物理量。",
    "category": "測量",
    "distractor_pool": "physical_quantity"
  },
  {
    "id": "pc0002",
    "term": "國際單位制",
    "unit": "measure_matter",
    "grade": "8",
    "def": "國際通用的測量單位系統，以公尺、公斤、秒等為基本單位。",
    "example": "國際單位制：跑道長用公尺、計時用秒，這些都是國際單位制的單位。",
    "category": "測量",
    "distractor_pool": "measurement_practice"
  },
  {
    "id": "pc0003",
    "term": "溫度",
    "unit": "measure_matter",
    "grade": "8",
    "def": "表示物體冷熱程度的物理量，常用攝氏溫標表示。",
    "example": "溫度：體溫計顯示 38.2°C，這個溫度比一般體溫高。",
    "category": "測量",
    "distractor_pool": "physical_quantity"
  },
  {
    "id": "pc0004",
    "term": "最小刻度",
    "unit": "measure_matter",
    "grade": "8",
    "def": "測量工具上相鄰兩刻度線所代表量值的差。",
    "example": "最小刻度：直尺每一小格是 1 毫米，因此它的最小刻度為 1 毫米。",
    "category": "測量",
    "distractor_pool": "measurement_practice"
  },
  {
    "id": "pc0005",
    "term": "視差",
    "unit": "measure_matter",
    "grade": "8",
    "def": "視線未與刻度面垂直而造成的讀值誤差。",
    "example": "視差：讀量筒時眼睛高於液面，所得數值可能因視差而偏小或偏大。",
    "category": "測量",
    "distractor_pool": "measurement_practice"
  },
  {
    "id": "pc0006",
    "term": "科學記號",
    "unit": "measure_matter",
    "grade": "8",
    "def": "將數寫成 a 乘以 10 的 n 次方，且 a 大於等於 1、小於 10 的表示法。",
    "example": "科學記號：地球到太陽約 150000000 公里，可用科學記號寫成 1.5×10^8 公里。",
    "category": "測量",
    "distractor_pool": "measurement_practice"
  },
  {
    "id": "pc0007",
    "term": "質量",
    "unit": "measure_matter",
    "grade": "8",
    "def": "物體所含物質的量，不因所在位置改變。",
    "example": "質量：同一顆球帶到月球後，天平測得的質量仍不改變。",
    "category": "物質性質",
    "distractor_pool": "physical_quantity"
  },
  {
    "id": "pc0008",
    "term": "體積",
    "unit": "measure_matter",
    "grade": "8",
    "def": "物體在空間中所占的大小。",
    "example": "體積：長 2 公分、寬 3 公分、高 4 公分的方塊，體積是 24 立方公分。",
    "category": "物質性質",
    "distractor_pool": "physical_quantity"
  },
  {
    "id": "pc0009",
    "term": "密度",
    "unit": "measure_matter",
    "grade": "8",
    "def": "單位體積物質的質量，可用質量除以體積求得。",
    "example": "密度：某金屬塊質量 54 公克、體積 20 立方公分，密度為 2.7 公克／立方公分。",
    "category": "物質性質",
    "distractor_pool": "physical_quantity"
  },
  {
    "id": "pc0010",
    "term": "排水法",
    "unit": "measure_matter",
    "grade": "8",
    "def": "把不溶於水且不吸水的物體完全浸沒，利用排開水的體積測定不規則物體體積的方法。",
    "example": "排水法：石頭完全沒入量筒後水面由 50 毫升升到 68 毫升，排水法測得體積為 18 立方公分。",
