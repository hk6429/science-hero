[
  {
    "id": "e0151",
    "term": "生態系",
    "unit": "environment",
    "grade": "5",
    "def": "生物和周遭非生物環境互相作用所形成的整體。",
    "example": "池塘生態系包含魚、水草、陽光、水和泥土。",
    "category": "生態關係",
    "distractor_pool": "ecosystem_concepts"
  },
  {
    "id": "e0152",
    "term": "生產者",
    "unit": "environment",
    "grade": "5",
    "def": "能利用陽光自行製造養分的生物，例如綠色植物。",
    "example": "水草是池塘生態系中的生產者。",
    "category": "生態關係",
    "distractor_pool": "ecosystem_relations"
  },
  {
    "id": "e0153",
    "term": "消費者",
